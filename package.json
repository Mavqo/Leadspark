{
  "name": "leadspark",
  "version": "1.0.0",
  "description": "AI Lead Capture Suite per Professionisti Salute & Benessere",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run build:css && astro build",
    "build:css": "tailwindcss -i ./src/styles/globals.css -o ./public/styles.css --minify",
    "start": "node ./dist/server/entry.mjs",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/node": "^8.0.0",
    "@astrojs/react": "^3.0.0",
    "astro": "^4.15.0",
    "openai": "^4.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
