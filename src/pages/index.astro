---
import Layout from "../layouts/Layout.astro";

const seo = {
  title: "AI Intake & Follow-up System | Portfolio Demo",
  description:
    "Demo responsive di intake strutturato e follow-up operativo per piccole attivita di servizi.",
  image: "https://images.unsplash.com/photo-1552664730-d307ca884978?w=1200&q=80"
};
---

<Layout title={seo.title} description={seo.description} image={seo.image} showNavigation={false}>
  <a href="#intake-form" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-slate-900 focus:text-white focus:px-4 focus:py-2 focus:rounded-lg">
    Salta al form
  </a>

  <div class="min-h-screen bg-gradient-to-b from-slate-50 via-white to-teal-50/40 text-slate-900">
    <header class="sticky top-0 z-40 border-b border-slate-200/80 bg-white/90 backdrop-blur-lg">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
        <a href="#" class="flex items-center gap-3 font-semibold tracking-tight">
          <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-teal-600 text-white">AI</span>
          <span>Intake & Follow-up</span>
        </a>
        <nav aria-label="Navigazione principale" class="hidden gap-7 text-sm font-medium text-slate-600 md:flex">
          <a href="#how-it-works" class="hover:text-slate-900 transition-colors">Workflow</a>
          <a href="#intake" class="hover:text-slate-900 transition-colors">Intake Demo</a>
          <a href="#evidence" class="hover:text-slate-900 transition-colors">Evidence</a>
        </nav>
        <a href="#intake-form" class="inline-flex items-center rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700 transition-colors">
          Avvia intake
        </a>
      </div>
    </header>

    <main>
      <section class="mx-auto grid max-w-6xl gap-8 px-4 pb-12 pt-10 sm:px-6 lg:grid-cols-2 lg:items-center lg:py-16">
        <div>
          <p class="inline-flex rounded-full border border-teal-200 bg-teal-100/70 px-3 py-1 text-sm font-semibold text-teal-800">
            Demo portfolio per SMB service businesses
          </p>
          <h1 class="mt-5 text-4xl font-bold leading-tight tracking-tight text-slate-900 sm:text-5xl">
            Intake strutturato, routing automatico, follow-up chiaro.
          </h1>
          <p class="mt-5 max-w-xl text-lg text-slate-600">
            Esperienza client-facing progettata per sostituire demo chatbot-heavy con una raccolta richiesta piu credibile, veloce e pronta per automazioni `n8n`.
          </p>
          <ul class="mt-6 space-y-3 text-sm text-slate-700" aria-label="Benefit principali">
            <li class="flex items-start gap-2"><span aria-hidden="true">✓</span> Form guidato con campi business-ready e priorita operativa</li>
            <li class="flex items-start gap-2"><span aria-hidden="true">✓</span> Stati UI completi: loading, errore, vuoto e successo</li>
            <li class="flex items-start gap-2"><span aria-hidden="true">✓</span> Integrazione API con fallback su contratto legacy</li>
          </ul>
        </div>

        <aside class="rounded-3xl border border-slate-200 bg-white p-6 shadow-xl shadow-slate-900/5" aria-label="Anteprima stato operativo">
          <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">Pipeline snapshot</p>
          <h2 class="mt-2 text-xl font-semibold">Stato demo in tempo reale</h2>
          <div class="mt-5 space-y-3 text-sm">
            <div class="flex items-center justify-between rounded-xl border border-slate-200 p-3">
              <span>Nuove richieste oggi</span>
              <strong class="text-teal-700">12</strong>
            </div>
            <div class="flex items-center justify-between rounded-xl border border-slate-200 p-3">
              <span>Tempo medio presa in carico</span>
              <strong class="text-teal-700">11 min</strong>
            </div>
            <div class="flex items-center justify-between rounded-xl border border-slate-200 p-3">
              <span>Follow-up automatico</span>
              <strong class="text-teal-700">Attivo</strong>
            </div>
          </div>
          <p class="mt-4 rounded-xl bg-slate-100 p-3 text-sm text-slate-600">
            Questa card rende il valore commerciale visibile subito, utile per screenshot portfolio e demo call.
          </p>
        </aside>
      </section>

      <section id="how-it-works" class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:py-10">
        <h2 class="text-2xl font-bold tracking-tight">Workflow in 3 step</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-3">
          <article class="rounded-2xl border border-slate-200 bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Step 1</p>
            <h3 class="mt-2 text-lg font-semibold">Raccolta intent</h3>
            <p class="mt-2 text-sm text-slate-600">Il form cattura contesto business, priorita e obiettivo con campi essenziali.</p>
          </article>
          <article class="rounded-2xl border border-slate-200 bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Step 2</p>
            <h3 class="mt-2 text-lg font-semibold">Routing API</h3>
            <p class="mt-2 text-sm text-slate-600">Invio su contratto intake primario con fallback sicuro per compatibilita.</p>
          </article>
          <article class="rounded-2xl border border-slate-200 bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Step 3</p>
            <h3 class="mt-2 text-lg font-semibold">Follow-up</h3>
            <p class="mt-2 text-sm text-slate-600">L'evento e pronto per trigger n8n: notifica, reminder e prima risposta.</p>
          </article>
        </div>
      </section>

      <section id="intake" class="mx-auto max-w-6xl px-4 pb-20 pt-8 sm:px-6">
        <div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-lg shadow-slate-900/5 sm:p-8">
            <div class="mb-6">
              <p class="text-sm font-semibold text-teal-700">Intake Demo</p>
              <h2 class="mt-1 text-2xl font-bold tracking-tight">Compila una richiesta cliente</h2>
              <p class="mt-2 text-sm text-slate-600">Campi progettati per SMB servizi locali. Tutti i campi marcati con * sono obbligatori.</p>
            </div>

            <form id="intake-form" class="space-y-5" novalidate>
              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <label for="businessName" class="block text-sm font-medium text-slate-800">Nome attivita *</label>
                  <input id="businessName" name="businessName" required autocomplete="organization" class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm" placeholder="Studio Alfa" />
                </div>
                <div>
                  <label for="contactName" class="block text-sm font-medium text-slate-800">Referente *</label>
                  <input id="contactName" name="contactName" required autocomplete="name" class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm" placeholder="Marco Bianchi" />
                </div>
              </div>

              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <label for="email" class="block text-sm font-medium text-slate-800">Email *</label>
                  <input id="email" name="email" type="email" required autocomplete="email" class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm" placeholder="marco@studio.it" />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-slate-800">Telefono *</label>
                  <input id="phone" name="phone" type="tel" required autocomplete="tel" class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm" placeholder="+39 333 000 0000" />
                </div>
              </div>

              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <label for="businessType" class="block text-sm font-medium text-slate-800">Settore *</label>
                  <select id="businessType" name="businessType" required class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm">
                    <option value="">Seleziona...</option>
                    <option value="clinica">Clinica / Studio medico</option>
                    <option value="beauty">Beauty / Wellness</option>
                    <option value="home_services">Servizi casa / artigiani</option>
                    <option value="legal_finance">Legale / consulenza</option>
                    <option value="other">Altro</option>
                  </select>
                </div>
                <div>
                  <label for="leadVolume" class="block text-sm font-medium text-slate-800">Richieste mensili stimate *</label>
                  <select id="leadVolume" name="leadVolume" required class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm">
                    <option value="">Seleziona...</option>
                    <option value="0-20">0-20</option>
                    <option value="21-50">21-50</option>
                    <option value="51-100">51-100</option>
                    <option value="100+">100+</option>
                  </select>
                </div>
              </div>

              <div>
                <label for="goal" class="block text-sm font-medium text-slate-800">Obiettivo prioritario *</label>
                <textarea id="goal" name="goal" rows="3" required class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm" placeholder="Es. ridurre i tempi di risposta ai nuovi lead e migliorare la conversione delle richieste ad alta priorita."></textarea>
              </div>

              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <label for="urgency" class="block text-sm font-medium text-slate-800">Urgenza operativa *</label>
                  <select id="urgency" name="urgency" required class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm">
                    <option value="">Seleziona...</option>
                    <option value="high">Alta - entro 7 giorni</option>
                    <option value="medium">Media - entro 30 giorni</option>
                    <option value="low">Bassa - esplorazione</option>
                  </select>
                </div>
                <div>
                  <label for="timeline" class="block text-sm font-medium text-slate-800">Timeline prevista *</label>
                  <input id="timeline" name="timeline" required class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm" placeholder="Es. kick-off entro fine mese" />
                </div>
              </div>

              <div>
                <label for="notes" class="block text-sm font-medium text-slate-800">Note aggiuntive</label>
                <textarea id="notes" name="notes" rows="2" class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm" placeholder="Stack attuale, CRM in uso, vincoli, ecc."></textarea>
              </div>

              <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                <label for="consent" class="flex items-start gap-3 text-sm text-slate-600">
                  <input id="consent" name="consent" type="checkbox" required class="mt-1 h-4 w-4 rounded border-slate-300" />
                  <span>Confermo che i dati inseriti sono reali e autorizzo il trattamento per la demo operativa.</span>
                </label>
              </div>

              <p id="form-error" class="hidden rounded-xl border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-700" role="alert"></p>

              <button id="submit-button" type="submit" class="inline-flex w-full items-center justify-center rounded-xl bg-teal-600 px-4 py-3 font-semibold text-white hover:bg-teal-700 disabled:cursor-not-allowed disabled:opacity-70">
                <span id="button-label">Invia richiesta demo</span>
              </button>
            </form>
          </div>

          <aside id="evidence" class="space-y-4">
            <div id="state-panel" class="rounded-3xl border border-slate-200 bg-white p-5 shadow-lg shadow-slate-900/5" aria-live="polite" aria-atomic="true">
              <p class="text-sm font-semibold text-slate-700">Stato invio</p>
              <p id="state-title" class="mt-2 text-lg font-semibold text-slate-900">Nessun invio effettuato</p>
              <p id="state-description" class="mt-1 text-sm text-slate-600">Compila il form per vedere la conferma e il riepilogo evento.</p>
            </div>

            <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-lg shadow-slate-900/5">
              <p class="text-sm font-semibold text-slate-700">Log workflow</p>
              <ol id="events-list" class="mt-3 space-y-2 text-sm text-slate-600">
                <li class="rounded-xl border border-slate-200 bg-slate-50 p-3">Nessun evento ancora disponibile.</li>
              </ol>
            </div>

            <div class="rounded-3xl border border-slate-200 bg-white p-5 text-sm text-slate-600 shadow-lg shadow-slate-900/5">
              <p class="font-semibold text-slate-800">Contract strategy</p>
              <p class="mt-2">Il frontend prova prima `/api/intake` (nuovo contratto). Se non disponibile, usa `/api/lead` con mapping compatibile.</p>
            </div>
          </aside>
        </div>
      </section>
    </main>
  </div>
</Layout>

<script>
  const form = document.getElementById("intake-form");
  const submitButton = document.getElementById("submit-button");
  const buttonLabel = document.getElementById("button-label");
  const errorNode = document.getElementById("form-error");
  const stateTitle = document.getElementById("state-title");
  const stateDescription = document.getElementById("state-description");
  const eventsList = document.getElementById("events-list");

  function setState(title, description) {
    stateTitle.textContent = title;
    stateDescription.textContent = description;
  }

  function setLoading(loading) {
    submitButton.disabled = loading;
    buttonLabel.textContent = loading ? "Invio in corso..." : "Invia richiesta demo";
  }

  function showError(message) {
    errorNode.textContent = message;
    errorNode.classList.remove("hidden");
  }

  function hideError() {
    errorNode.textContent = "";
    errorNode.classList.add("hidden");
  }

  function appendEvents(items) {
    eventsList.innerHTML = "";
    for (const item of items) {
      const li = document.createElement("li");
      li.className = "rounded-xl border border-slate-200 bg-slate-50 p-3";
      li.textContent = item;
      eventsList.appendChild(li);
    }
  }

  function validateForm() {
    const requiredFields = [
      "businessName",
      "contactName",
      "email",
      "phone",
      "businessType",
      "leadVolume",
      "goal",
      "urgency",
      "timeline",
      "consent"
    ];

    for (const name of requiredFields) {
      const field = form.elements.namedItem(name);
      if (!field) return false;
      if (field instanceof HTMLInputElement && field.type === "checkbox" && !field.checked) {
        return false;
      }
      if ((field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement) && !field.value.trim()) {
        return false;
      }
    }

    return true;
  }

  function mapUrgencyToLegacy(value) {
    if (value === "high") return "alta";
    if (value === "medium") return "media";
    return "bassa";
  }

  function mapServiceType(value) {
    if (["clinica", "beauty", "home_services"].includes(value)) return "automation";
    if (value === "legal_finance") return "intake_optimization";
    return "other";
  }

  function buildIntakeContractPayload(payload) {
    return {
      name: payload.contactName,
      email: payload.email,
      phone: payload.phone,
      company: payload.businessName,
      message: [
        `Obiettivo: ${payload.goal}`,
        `Settore: ${payload.businessType}`,
        `Richieste/mese: ${payload.leadVolume}`,
        `Timeline: ${payload.timeline}`,
        payload.notes ? `Note: ${payload.notes}` : null
      ].filter(Boolean).join(" | "),
      serviceType: mapServiceType(payload.businessType),
      urgency: payload.urgency,
      consent: payload.consent,
      source: payload.source
    };
  }

  async function submitIntake(payload) {
    const intakePayload = buildIntakeContractPayload(payload);
    const primaryRes = await fetch("/api/intake", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(intakePayload)
    });

    if (primaryRes.ok) {
      return { endpoint: "/api/intake", response: await primaryRes.json() };
    }

    if (![404, 405].includes(primaryRes.status)) {
      const data = await primaryRes.json().catch(() => ({}));
      const message = data?.error || "Errore durante invio al contratto intake";
      throw new Error(message);
    }

    const legacyPayload = {
      name: payload.contactName,
      phone: payload.phone,
      email: payload.email,
      sintomi: payload.goal,
      durata: payload.timeline,
      urgenza: mapUrgencyToLegacy(payload.urgency),
      disponibilita: `Volume richieste: ${payload.leadVolume}`,
      notes: `${payload.businessName} | Settore: ${payload.businessType} | ${payload.notes || "no-notes"}`
    };

    const fallbackRes = await fetch("/api/lead", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(legacyPayload)
    });

    const fallbackJson = await fallbackRes.json().catch(() => ({}));
    if (!fallbackRes.ok) {
      throw new Error(fallbackJson?.error || "Errore durante invio fallback su /api/lead");
    }

    return { endpoint: "/api/lead", response: fallbackJson };
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    hideError();

    if (!validateForm()) {
      showError("Completa tutti i campi obbligatori prima di inviare.");
      setState("Dati incompleti", "Verifica i campi obbligatori evidenziati nel form.");
      return;
    }

    const formData = new FormData(form);
    const payload = {
      businessName: String(formData.get("businessName") || "").trim(),
      contactName: String(formData.get("contactName") || "").trim(),
      email: String(formData.get("email") || "").trim(),
      phone: String(formData.get("phone") || "").trim(),
      businessType: String(formData.get("businessType") || "").trim(),
      leadVolume: String(formData.get("leadVolume") || "").trim(),
      goal: String(formData.get("goal") || "").trim(),
      urgency: String(formData.get("urgency") || "").trim(),
      timeline: String(formData.get("timeline") || "").trim(),
      notes: String(formData.get("notes") || "").trim(),
      consent: Boolean(formData.get("consent")),
      source: "portfolio_demo"
    };

    setLoading(true);
    setState("Invio in corso", "Stiamo validando il payload e inviando la richiesta...");

    try {
      const result = await submitIntake(payload);
      const ticketId =
        result.response?.intakeId || result.response?.pazienteId || result.response?.id || "n/a";

      setState(
        "Richiesta inviata con successo",
        `Endpoint usato: ${result.endpoint}. ID evento: ${ticketId}.`
      );

      appendEvents([
        `1) Payload validato lato client alle ${new Date().toLocaleTimeString("it-IT")}`,
        `2) Richiesta inviata a ${result.endpoint}`,
        "3) Evento pronto per routing n8n e follow-up operativo"
      ]);

      form.reset();
    } catch (error) {
      const message = error instanceof Error ? error.message : "Errore imprevisto durante invio";
      showError(message);
      setState("Invio fallito", "Controlla il messaggio errore e riprova.");
      appendEvents([
        `Errore: ${message}`,
        "Verifica disponibilita endpoint API e contratto payload"
      ]);
    } finally {
      setLoading(false);
    }
  });
</script>
