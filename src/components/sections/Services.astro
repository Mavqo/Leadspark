---
const services = [
  {
    icon: "activity",
    title: "Fisioterapia Sportiva",
    description: "Trattamenti specializzati per atleti e sportivi di ogni livello. Recupero ottimale da infortuni muscolari, articolari e tendinei.",
    features: ["Riabilitazione post-infortunio", "Prevenzione infortuni", "Miglioramento prestazioni"],
    color: "blue",
    image: "https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=400&q=80"
  },
  {
    icon: "heartpulse",
    title: "Riabilitazione Post-operatoria",
    description: "Percorsi di recupero personalizzati dopo interventi chirurgici. Ritorna alle tue attività quotidiane in modo sicuro e graduale.",
    features: ["Recupero funzionale", "Terapia del dolore", "Supporto psicologico"],
    color: "emerald",
    image: "https://images.unsplash.com/photo-1551076805-e1869033e561?w=400&q=80"
  },
  {
    icon: "hand",
    title: "Terapia Manuale",
    description: "Tecniche manuali avanzate per il trattamento di dolori muscoloscheletrici, tensioni croniche e problematiche posturali.",
    features: ["Osteopatia", "Massoterapia", "Mobilizzazione articolare"],
    color: "teal",
    image: "https://images.unsplash.com/photo-1544161515-4ab6ce6db874?w=400&q=80"
  }
];

const colorClasses: Record<string, { bg: string; text: string; border: string; gradient: string; shadow: string }> = {
  blue: {
    bg: "bg-blue-100 dark:bg-blue-900/30",
    text: "text-blue-600 dark:text-blue-400",
    border: "border-blue-200 dark:border-blue-800",
    gradient: "from-blue-500 to-blue-600",
    shadow: "shadow-blue-500/20 hover:shadow-blue-500/30"
  },
  emerald: {
    bg: "bg-emerald-100 dark:bg-emerald-900/30",
    text: "text-emerald-600 dark:text-emerald-400",
    border: "border-emerald-200 dark:border-emerald-800",
    gradient: "from-emerald-500 to-emerald-600",
    shadow: "shadow-emerald-500/20 hover:shadow-emerald-500/30"
  },
  teal: {
    bg: "bg-teal-100 dark:bg-teal-900/30",
    text: "text-teal-600 dark:text-teal-400",
    border: "border-teal-200 dark:border-teal-800",
    gradient: "from-teal-500 to-teal-600",
    shadow: "shadow-teal-500/20 hover:shadow-teal-500/30"
  }
};
---

<section id="services" class="section-padding bg-slate-50 dark:bg-slate-800/50">
  <div class="max-w-7xl mx-auto container-padding">
    {/* Section Header */}
    <div class="text-center max-w-3xl mx-auto mb-16 reveal">
      <span class="inline-block px-4 py-1.5 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-sm font-semibold mb-4">
        I Nostri Servizi
      </span>
      <h2 class="text-slate-900 dark:text-white mb-6">
        Soluzioni di fisioterapia
        <span class="text-gradient"> su misura per te</span>
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
        Offriamo trattamenti personalizzati basati sulle più recenti evidenze scientifiche, 
        utilizzando tecnologie all'avanguardia e tecniche manuali specializzate.
      </p>
    </div>

    {/* Services Grid */}
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 stagger-children">
      {services.map((service, index) => {
        const colors = colorClasses[service.color];
        
        return (
          <article class={`group bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 overflow-hidden rounded-2xl shadow-md ${colors.shadow} transition-all duration-500 hover:-translate-y-2 hover:shadow-xl`}>
            {/* Image Header */}
            <div class="relative h-48 overflow-hidden">
              <img 
                src={service.image} 
                alt={service.title}
                class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
              
              {/* Icon Badge */}
              <div class={`absolute top-4 right-4 w-12 h-12 rounded-xl ${colors.bg} ${colors.text} flex items-center justify-center shadow-lg transform group-hover:scale-110 group-hover:rotate-3 transition-all duration-300`}>
                {service.icon === "activity" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M22 12h-2.5"/><path d="M9 12v2"/><path d="M9 18v2"/><path d="M9 6V4"/><path d="M6 12h13"/><path d="M6 6h1.5"/><path d="M6 18h1.5"/><path d="M4 12a2 2 0 0 1-2-2v-.5a.5.5 0 0 1 .5-.5 2 2 0 1 1 0 4 .5.5 0 0 1-.5-.5V14a2 2 0 0 1 2-2z"/><path d="M17 12a2 2 0 0 1 2-2v-.5a.5.5 0 0 0-.5-.5 2 2 0 1 0 0 4 .5.5 0 0 0 .5-.5V14a2 2 0 0 0-2-2z"/></svg>
                )}
                {service.icon === "heartpulse" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"/><path d="M3.22 13H9.5l.5-1 2 4.5 2-7 1.5 3.5h5.27"/></svg>
                )}
                {service.icon === "hand" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M18 12.5V10a2 2 0 0 0-2-2a2 2 0 0 0-2 2v1.5"/><path d="M14 11V9a2 2 0 1 0-4 0v2"/><path d="M10 10.5V5a2 2 0 1 0-4 0v9"/><path d="m7 15-1.76-1.76a2 2 0 0 0-2.83 2.82l3.6 3.6C7.5 21.14 9.2 22 12 22h2a8 8 0 0 0 8-8V7a2 2 0 1 0-4 0v5"/></svg>
                )}
              </div>
              
              {/* Title Overlay */}
              <div class="absolute bottom-4 left-4 right-4">
                <h3 class="text-xl text-white font-bold drop-shadow-lg">
                  {service.title}
                </h3>
              </div>
            </div>

            <div class="p-6">
              <p class="text-slate-600 dark:text-slate-300 text-base leading-relaxed mb-5">
                {service.description}
              </p>

              {/* Features List */}
              <ul class="space-y-3 mb-6">
                {service.features.map((feature, featureIndex) => (
                  <li class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-400 group/feature">
                    <div class={`w-2 h-2 rounded-full bg-gradient-to-r ${colors.gradient} transform group-hover/feature:scale-125 transition-transform duration-200`}></div>
                    <span class="group-hover/feature:text-slate-800 dark:group-hover/feature:text-slate-200 transition-colors duration-200">{feature}</span>
                  </li>
                ))}
              </ul>

              {/* CTA Button */}
              <a href="#contact" class="block">
                <button 
                  class={`w-full flex items-center justify-center gap-2 px-4 py-3 rounded-xl font-semibold transition-all duration-300 ${colors.text} ${colors.bg} hover:opacity-90 group/btn`}
                >
                  Scopri di più
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1 h-4 w-4 transform group-hover/btn:translate-x-1 transition-transform duration-300"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </button>
              </a>
            </div>
          </article>
        );
      })}
    </div>

    {/* Bottom CTA */}
    <div class="mt-16 lg:mt-20 reveal">
      <div class="inline-flex flex-col sm:flex-row items-center gap-4 sm:gap-6 p-6 sm:p-8 rounded-2xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-lg hover:shadow-xl transition-shadow duration-300">
        <div class="text-center sm:text-left">
          <p class="font-bold text-lg text-slate-900 dark:text-white">Non sei sicuro di quale servizio fa per te?</p>
          <p class="text-slate-600 dark:text-slate-400">Prenota una consulenza gratuita e ti aiuteremo a scegliere</p>
        </div>
        <a href="#contact" class="w-full sm:w-auto">
          <button class="btn-shine btn-ripple w-full sm:w-auto flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 dark:bg-blue-600 dark:hover:bg-blue-500 text-white rounded-full px-8 py-3 font-semibold shadow-lg shadow-blue-500/25 hover:shadow-blue-500/40 transition-all duration-300 hover:-translate-y-0.5">
            Contattaci ora
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1 h-4 w-4"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </button>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /* Stagger animation for service cards */
  .stagger-children > * {
    opacity: 0;
    transform: translateY(20px);
  }
  
  .stagger-children.visible > *:nth-child(1) {
    animation: slideUpCard 0.6s var(--ease-out-expo) 0ms forwards;
  }
  
  .stagger-children.visible > *:nth-child(2) {
    animation: slideUpCard 0.6s var(--ease-out-expo) 0.1s forwards;
  }
  
  .stagger-children.visible > *:nth-child(3) {
    animation: slideUpCard 0.6s var(--ease-out-expo) 0.2s forwards;
  }
  
  @keyframes slideUpCard {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* Card shine effect on hover */
  .group::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.1),
      transparent
    );
    transition: left 0.7s ease;
    pointer-events: none;
    z-index: 10;
  }
  
  .group:hover::before {
    left: 100%;
  }
</style>
