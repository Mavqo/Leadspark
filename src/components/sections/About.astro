---
import { Award, GraduationCap, Users, Calendar } from "lucide-react";

const team = [
  {
    name: "Dott. Marco Rossi",
    role: "Fisioterapista Specialista",
    specialization: "Riabilitazione Sportiva",
    image: "https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=400&q=80",
    experience: "15+ anni",
    education: "Laurea in Fisioterapia, Master in Sport",
    certifications: ["AIFI", "FMS Level 2", "DNS"]
  },
  {
    name: "Dott.ssa Laura Bianchi",
    role: "Fisioterapista Osteopata",
    specialization: "Terapia Manuale & Osteopatia",
    image: "https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=400&q=80",
    experience: "12+ anni",
    education: "Laurea in Fisioterapia, D.O. Osteopatia",
    certifications: ["ROI", "IATM", "Fascial Manipulation"]
  },
  {
    name: "Dott. Giuseppe Verdi",
    role: "Fisioterapista Specialista",
    specialization: "Riabilitazione Neurologica",
    image: "https://images.unsplash.com/photo-1622253692010-333f2da6031d?w=400&q=80",
    experience: "10+ anni",
    education: "Laurea in Fisioterapia, Specializzazione Neuro",
    certifications: ["AIFI", "Bobath", "PNF"]
  }
];

const stats = [
  { icon: Calendar, value: "15+", label: "Anni di esperienza" },
  { icon: Users, value: "5000+", label: "Pazienti trattati" },
  { icon: Award, value: "25+", label: "Certificazioni" },
  { icon: GraduationCap, value: "100%", label: "Team specializzato" }
];
---

<section id="about" class="section-padding bg-white dark:bg-slate-900">
  <div class="max-w-7xl mx-auto container-padding">
    {/* Section Header */}
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block px-4 py-1.5 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300 text-sm font-medium mb-4">
        Chi Siamo
      </span>
      <h2 class="text-slate-900 dark:text-white mb-6">
        Un team di professionisti
        <span class="text-gradient"> dedicati al tuo benessere</span>
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-300">
        Da oltre 15 anni accompagniamo i nostri pazienti nel percorso di recupero, 
        combinando esperienza, aggiornamento continuo e approccio umano.
      </p>
    </div>

    {/* Stats Row */}
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 mb-16">
      {stats.map((stat) => {
        const Icon = stat.icon;
        return (
          <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl text-center p-6">
            <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center">
              <Icon class="w-6 h-6 text-blue-600 dark:text-blue-400" />
            </div>
            <p class="text-3xl font-bold text-slate-900 dark:text-white mb-1">{stat.value}</p>
            <p class="text-sm text-slate-600 dark:text-slate-400">{stat.label}</p>
          </div>
        );
      })}
    </div>

    {/* Team Grid */}
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {team.map((member) => (
        <div class="group bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl overflow-hidden shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          {/* Image Container */}
          <div class="relative h-72 overflow-hidden">
            <img 
              src={member.image} 
              alt={member.name}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-slate-900/20 to-transparent"></div>
            
            {/* Info Overlay */}
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <h3 class="text-xl font-bold text-white mb-1">{member.name}</h3>
              <p class="text-emerald-400 font-medium">{member.role}</p>
            </div>
          </div>

          <div class="p-6">
            {/* Specialization */}
            <div class="mb-4">
              <p class="text-xs uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1">Specializzazione</p>
              <p class="text-slate-700 dark:text-slate-300 font-medium">{member.specialization}</p>
            </div>

            {/* Details */}
            <div class="space-y-3 mb-4">
              <div class="flex items-center gap-3 text-sm">
                <Calendar class="w-4 h-4 text-blue-500" />
                <span class="text-slate-600 dark:text-slate-400">{member.experience} di esperienza</span>
              </div>
              <div class="flex items-start gap-3 text-sm">
                <GraduationCap class="w-4 h-4 text-emerald-500 mt-0.5" />
                <span class="text-slate-600 dark:text-slate-400">{member.education}</span>
              </div>
            </div>

            {/* Certifications */}
            <div class="flex flex-wrap gap-2">
              {member.certifications.map((cert) => (
                <span class="inline-flex items-center px-2.5 py-1 rounded-md bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 text-xs font-medium">
                  <Award class="w-3 h-3 mr-1" />
                  {cert}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    {/* Mission Statement */}
    <div class="mt-16 p-8 md:p-12 rounded-3xl bg-gradient-to-br from-blue-600 to-blue-700 dark:from-blue-700 dark:to-blue-800 text-white">
      <div class="max-w-3xl mx-auto text-center">
        <h3 class="text-2xl md:text-3xl font-bold mb-4">La nostra missione</h3>
        <p class="text-lg text-blue-100 leading-relaxed">
          Crediamo che ogni paziente meriti un percorso di cura personalizzato, basato sulle più 
          recenti evidenze scientifiche e sul rispetto dei tempi individuali. Il nostro obiettivo 
          non è solo alleviare il dolore, ma restituire autonomia e qualità di vita a ogni persona 
          che ci affida la propria salute.
        </p>
      </div>
    </div>
  </div>
</section>
