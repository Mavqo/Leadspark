---
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background Gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-white to-emerald-50 dark:from-slate-900 dark:via-slate-800 dark:to-slate-900">
    <!-- Animated Decorative Elements -->
    <div class="absolute top-20 right-10 w-72 h-72 bg-blue-400/10 dark:bg-blue-500/10 rounded-full blur-3xl animate-pulse" style="animation-duration: 4s;"></div>
    <div class="absolute bottom-20 left-10 w-96 h-96 bg-emerald-400/10 dark:bg-emerald-500/10 rounded-full blur-3xl animate-pulse" style="animation-duration: 5s; animation-delay: 1s;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-radial from-blue-100/50 dark:from-blue-900/20 to-transparent rounded-full"></div>
    
    <!-- Additional floating shapes -->
    <div class="absolute top-1/4 right-1/4 w-32 h-32 bg-teal-300/10 dark:bg-teal-500/10 rounded-full blur-2xl animate-float"></div>
    <div class="absolute bottom-1/3 right-1/3 w-24 h-24 bg-blue-300/10 dark:bg-blue-500/10 rounded-full blur-2xl animate-float" style="animation-delay: 1.5s;"></div>
  </div>

  <!-- Content -->
  <div class="relative w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 xl:px-12 py-16 lg:py-24">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left Column - Text Content -->
      <div class="text-center lg:text-left space-y-6 lg:space-y-8">
        <!-- Badge -->
        <div 
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-sm font-medium animate-fade-in"
          style="animation-delay: 0ms;"
        >
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-blue-500"></span>
          </span>
          Centro di eccellenza certificato
        </div>

        <!-- Headline -->
        <h1 
          class="font-bold leading-[1.1] tracking-tight"
          style="animation: slideUp 0.8s var(--ease-out-expo) 0.1s forwards; opacity: 0;"
        >
          <span class="text-slate-900 dark:text-white">Riprendi il</span>
          <br />
          <span class="text-gradient">controllo del tuo corpo</span>
        </h1>

        <!-- Subheadline -->
        <p 
          class="text-lg md:text-xl text-slate-600 dark:text-slate-300 max-w-xl mx-auto lg:mx-0 leading-relaxed"
          style="animation: slideUp 0.8s var(--ease-out-expo) 0.2s forwards; opacity: 0;"
        >
          Fisioterapia specializzata per il tuo benessere. Un team di professionisti dedicati a guidarti nel percorso di recupero e miglioramento della tua qualità di vita.
        </p>

        <!-- CTA Buttons -->
        <div 
          class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start"
          style="animation: slideUp 0.8s var(--ease-out-expo) 0.3s forwards; opacity: 0;"
        >
          <a href="#contact" class="group">
            <button 
              class="btn-shine btn-ripple relative bg-blue-600 hover:bg-blue-700 dark:bg-blue-600 dark:hover:bg-blue-500 text-white px-8 py-4 text-base rounded-full shadow-xl shadow-blue-500/25 hover:shadow-blue-500/40 transition-all duration-300 inline-flex items-center font-semibold hover:-translate-y-1 active:translate-y-0"
            >
              Prenota una visita
              <svg class="ml-2 h-5 w-5 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </button>
          </a>
          <a href="#services" class="group">
            <button 
              class="px-8 py-4 text-base rounded-full border-2 border-slate-300 dark:border-slate-600 hover:border-blue-500 dark:hover:border-blue-500 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-300 text-slate-700 dark:text-slate-200 bg-transparent font-semibold hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:-translate-y-1 active:translate-y-0"
            >
              Scopri i servizi
            </button>
          </a>
        </div>

        <!-- Quick Info -->
        <div 
          class="flex flex-col sm:flex-row gap-4 sm:gap-6 justify-center lg:justify-start pt-4 text-sm text-slate-600 dark:text-slate-400"
          style="animation: slideUp 0.8s var(--ease-out-expo) 0.4s forwards; opacity: 0;"
        >
          <div class="flex items-center gap-2 group cursor-default">
            <div class="w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center group-hover:scale-110 transition-transform duration-200">
              <svg class="h-4 w-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <span>Lun-Ven: 9:00-19:00</span>
          </div>
          <div class="flex items-center gap-2 group cursor-default">
            <div class="w-8 h-8 rounded-lg bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center group-hover:scale-110 transition-transform duration-200">
              <svg class="h-4 w-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
            </div>
            <span>+39 02 1234 5678</span>
          </div>
          <div class="flex items-center gap-2 group cursor-default">
            <div class="w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center group-hover:scale-110 transition-transform duration-200">
              <svg class="h-4 w-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <span>Milano, Italia</span>
          </div>
        </div>
      </div>

      <!-- Right Column - Image/Illustration -->
      <div class="relative hidden lg:block">
        <div class="relative">
          <!-- Main Image -->
          <div 
            class="relative rounded-3xl overflow-hidden shadow-2xl"
            style="animation: scaleIn 0.8s var(--ease-out-back) 0.3s forwards; opacity: 0;"
          >
            <img 
              src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=800&q=80" 
              alt="Fisioterapista professionista al lavoro"
              class="w-full h-[500px] object-cover"
              loading="eager"
              decoding="async"
            />
            <!-- Overlay Gradient -->
            <div class="absolute inset-0 bg-gradient-to-t from-blue-900/30 via-transparent to-transparent"></div>
          </div>

          <!-- Floating Card 1 - Stats -->
          <div 
            class="absolute -bottom-4 -left-6 bg-white dark:bg-slate-800 rounded-2xl p-5 shadow-xl border border-slate-100 dark:border-slate-700 hover:-translate-y-1 hover:shadow-2xl transition-all duration-300 cursor-default"
            style="animation: floatUp 0.8s var(--ease-out-back) 0.5s forwards; opacity: 0;"
          >
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center">
                <svg class="w-6 h-6 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <p class="text-2xl font-bold text-slate-900 dark:text-white">15+</p>
                <p class="text-sm text-slate-500 dark:text-slate-400">Anni di esperienza</p>
              </div>
            </div>
          </div>

          <!-- Floating Card 2 - Rating -->
          <div 
            class="absolute -top-2 -right-4 bg-white dark:bg-slate-800 rounded-2xl p-5 shadow-xl border border-slate-100 dark:border-slate-700 hover:-translate-y-1 hover:shadow-2xl transition-all duration-300 cursor-default"
            style="animation: floatUp 0.8s var(--ease-out-back) 0.7s forwards; opacity: 0;"
          >
            <div class="flex items-center gap-3">
              <div class="flex">
                {[...Array(5)].map(() => (
                  <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <div>
                <p class="text-lg font-bold text-slate-900 dark:text-white">4.9</p>
              </div>
            </div>
            <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">200+ recensioni</p>
          </div>

          <!-- Floating Badge - Certified -->
          <div 
            class="absolute top-1/2 -right-6 bg-blue-600 dark:bg-blue-500 text-white rounded-2xl p-4 shadow-lg animate-float cursor-default hover:scale-110 transition-transform duration-300"
            style="animation-delay: 0.5s;"
          >
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path>
            </svg>
          </div>
        </div>
      </div>

      <!-- Mobile Image -->
      <div class="lg:hidden relative">
        <div 
          class="rounded-2xl overflow-hidden shadow-xl"
          style="animation: scaleIn 0.6s var(--ease-out-back) forwards;"
        >
          <img 
            src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=600&q=80" 
            alt="Fisioterapista professionista al lavoro"
            class="w-full h-64 object-cover"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden lg:block animate-bounce" style="animation-duration: 2s;">
    <a href="#services" class="flex flex-col items-center gap-2 text-slate-400 hover:text-blue-500 transition-colors duration-300 group">
      <span class="text-xs uppercase tracking-widest font-medium">Scorri</span>
      <div class="w-6 h-10 rounded-full border-2 border-current flex justify-center pt-2">
        <div class="w-1 h-2 bg-current rounded-full animate-bounce"></div>
      </div>
    </a>
  </div>
</section>

<style>
  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes scaleIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
  
  @keyframes floatUp {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  
  /* Ensure animations respect reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
    
    [style*="animation"],
    [style*="opacity: 0"] {
      opacity: 1 !important;
      animation: none !important;
    }
  }
</style>
