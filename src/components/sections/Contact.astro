---
const contactInfo = [
  {
    icon: "phone",
    label: "Telefono",
    value: "+39 02 1234 5678",
    href: "tel:+390212345678",
    description: "Chiamaci per urgenze"
  },
  {
    icon: "mail",
    label: "Email",
    value: "info@movimento.it",
    href: "mailto:info@movimento.it",
    description: "Rispondiamo entro 24h"
  },
  {
    icon: "mapPin",
    label: "Indirizzo",
    value: "Via Roma 123, Milano",
    href: "https://maps.google.com",
    description: "Facilmente raggiungibile"
  },
  {
    icon: "clock",
    label: "Orari",
    value: "Lun-Ven: 9:00-19:00",
    description: "Sabato su appuntamento"
  }
];

const icons = {
  phone: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  mail: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  mapPin: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
  clock: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
};
---

<section id="contact" class="section-padding bg-white dark:bg-slate-900">
  <div class="max-w-7xl mx-auto container-padding">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 reveal">
      <span class="inline-block px-4 py-1.5 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-sm font-semibold mb-4">
        Contattaci
      </span>
      <h2 class="text-slate-900 dark:text-white mb-6">
        Prenota la tua visita
        <span class="text-gradient"> oggi stesso</span>
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
        Siamo qui per aiutarti. Compila il form per richiedere una consulenza gratuita 
        o contattaci direttamente per una risposta immediata.
      </p>
    </div>

    <div class="grid lg:grid-cols-5 gap-8 lg:gap-12">
      <!-- Contact Form -->
      <div class="lg:col-span-3 reveal">
        <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-lg hover:shadow-xl transition-shadow duration-300 rounded-2xl overflow-hidden">
          <div class="p-6 pb-6 border-b border-slate-200 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-800/50">
            <h3 class="text-xl text-slate-900 dark:text-white flex items-center gap-2 font-bold">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-blue-600 dark:text-blue-400"><path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"/><path d="m21.854 2.147-10.94 10.939"/></svg>
              Richiedi informazioni
            </h3>
          </div>
          <div class="p-6">
            <form id="contact-form" class="space-y-6" action="#" method="POST">
              <!-- Name & Email Row -->
              <div class="grid sm:grid-cols-2 gap-4">
                <div class="space-y-2">
                  <label for="name" class="form-label">
                    Nome completo <span class="text-red-500">*</span>
                  </label>
                  <input 
                    id="name"
                    name="name"
                    type="text"
                    placeholder="Mario Rossi"
                    required
                    class="form-input"
                  />
                </div>
                <div class="space-y-2">
                  <label for="email" class="form-label">
                    Email <span class="text-red-500">*</span>
                  </label>
                  <input 
                    id="email"
                    name="email"
                    type="email"
                    placeholder="mario@email.it"
                    required
                    class="form-input"
                  />
                </div>
              </div>

              <!-- Phone -->
              <div class="space-y-2">
                <label for="phone" class="form-label">Telefono</label>
                <input 
                  id="phone"
                  name="phone"
                  type="tel"
                  placeholder="+39 333 123 4567"
                  class="form-input"
                />
              </div>

              <!-- Service Selection -->
              <div class="space-y-2">
                <label for="service" class="form-label">Servizio di interesse</label>
                <select id="service" name="service" class="form-input cursor-pointer">
                  <option value="">Seleziona un servizio...</option>
                  <option value="website">Sito Web / Presenza Online</option>
                  <option value="automation">Automazione e CRM</option>
                  <option value="intake_optimization">Ottimizzazione Acquisizione Clienti</option>
                  <option value="other">Altro / Non so</option>
                </select>
              </div>

              <!-- Message -->
              <div class="space-y-2">
                <label for="message" class="form-label">
                  Messaggio <span class="text-red-500">*</span>
                </label>
                <textarea 
                  id="message"
                  name="message"
                  placeholder="Descrivi il tuo problema o richiesta..."
                  required
                  rows="4"
                  class="form-input resize-none"
                ></textarea>
              </div>

              <!-- Privacy Checkbox -->
              <div class="flex items-start gap-3">
                <input 
                  type="checkbox" 
                  id="privacy" 
                  name="privacy"
                  required
                  class="mt-1 w-4 h-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500 focus:ring-2 cursor-pointer"
                />
                <label for="privacy" class="text-sm text-slate-600 dark:text-slate-400">
                  Ho letto e accetto la 
                  <a href="#" class="text-blue-600 dark:text-blue-400 hover:underline font-medium">Privacy Policy</a>
                  e autorizzo il trattamento dei miei dati personali.
                </label>
              </div>

              <!-- Submit Button -->
              <button 
                type="submit"
                id="submit-btn"
                class="w-full btn-shine btn-ripple bg-blue-600 hover:bg-blue-700 dark:bg-blue-600 dark:hover:bg-blue-500 text-white py-4 px-6 rounded-xl font-semibold text-base flex items-center justify-center gap-2 transition-all duration-300 shadow-lg shadow-blue-500/25 hover:shadow-blue-500/40 hover:-translate-y-0.5 active:translate-y-0"
              >
                <span id="btn-text">Invia richiesta</span>
                <svg id="btn-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 transition-transform duration-300"><path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"/><path d="m21.854 2.147-10.94 10.939"/></svg>
                <svg id="btn-spinner" class="hidden w-5 h-5 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
              </button>

              <p class="text-xs text-slate-500 dark:text-slate-400 text-center">
                Risponderemo alla tua richiesta entro 24 ore lavorative.
              </p>
            </form>
          </div>
        </div>
      </div>

      <!-- Contact Info & Map -->
      <div class="lg:col-span-2 space-y-6 reveal" style="animation-delay: 0.1s;">
        <!-- Contact Cards -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-1 gap-4 stagger-children">
          {contactInfo.map((info) => (
            <a 
              href={info.href}
              class="group flex items-start gap-4 p-4 rounded-xl bg-slate-50 dark:bg-slate-800/50 hover:bg-blue-50 dark:hover:bg-blue-900/20 border border-slate-200 dark:border-slate-700 hover:border-blue-200 dark:hover:border-blue-800 transition-all duration-300 hover:-translate-y-1"
            >
              <div class="w-12 h-12 rounded-xl bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center flex-shrink-0 group-hover:bg-blue-600 dark:group-hover:bg-blue-500 group-hover:scale-110 transition-all duration-300">
                <Fragment set:html={icons[info.icon]} class="text-blue-600 dark:text-blue-400 group-hover:text-white transition-colors duration-300" />
              </div>
              <div>
                <p class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider font-semibold mb-1">{info.label}</p>
                <p class="font-bold text-slate-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors duration-200">{info.value}</p>
                <p class="text-sm text-slate-500 dark:text-slate-400">{info.description}</p>
              </div>
            </a>
          ))}
        </div>

        {/* Quick CTA */}
        <div class="bg-gradient-to-br from-emerald-500 via-emerald-600 to-emerald-700 dark:from-emerald-600 dark:via-emerald-700 dark:to-emerald-800 text-white border-0 rounded-2xl overflow-hidden shadow-lg shadow-emerald-500/20 hover:shadow-emerald-500/30 transition-shadow duration-300">
          <div class="p-6 relative overflow-hidden">
            {/* Decorative circle */}
            <div class="absolute -top-8 -right-8 w-32 h-32 bg-white/10 rounded-full"></div>
            
            <div class="flex items-center gap-3 mb-3 relative">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
              <h3 class="font-bold text-lg">Prenota ora</h3>
            </div>
            <p class="text-emerald-100 text-sm mb-4 relative">
              Richiedi una consulenza gratuita di 15 minuti per valutare insieme il tuo percorso terapeutico.
            </p>
            <a href="tel:+390212345678">
              <button 
                class="w-full bg-white text-emerald-600 hover:bg-emerald-50 py-3 px-4 rounded-xl font-semibold text-sm flex items-center justify-center gap-2 transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                Chiama ora
              </button>
            </a>
          </div>
        </div>

        {/* Map Placeholder */}
        <div class="rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-700 bg-slate-100 dark:bg-slate-800 shadow-sm hover:shadow-md transition-shadow duration-300">
          <div class="relative h-48 bg-gradient-to-br from-slate-200 via-slate-300 to-slate-200 dark:from-slate-700 dark:via-slate-600 dark:to-slate-700 flex items-center justify-center">
            <div class="text-center relative z-10">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-slate-400 mx-auto mb-2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              <p class="text-slate-600 dark:text-slate-300 text-sm font-medium">Mappa interattiva</p>
              <p class="text-slate-500 dark:text-slate-400 text-xs">Via Roma 123, Milano</p>
            </div>
            <div class="absolute inset-0 bg-gradient-to-br from-slate-200 via-slate-300 to-slate-200 dark:from-slate-700 dark:via-slate-600 dark:to-slate-700 opacity-50"></div>
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
              <div class="w-4 h-4 bg-blue-600 rounded-full animate-ping absolute"></div>
              <div class="w-4 h-4 bg-blue-600 rounded-full relative border-2 border-white dark:border-slate-800"></div>
            </div>
          </div>
          <div class="p-4 bg-white dark:bg-slate-800">
            <a 
              href="https://maps.google.com" 
              target="_blank" 
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 text-sm text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-semibold transition-colors duration-200 group"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              Apri in Google Maps
            </a>
          </div>
        </div>

        {/* Success Guarantee */}
        <div class="flex items-center gap-4 p-4 rounded-xl bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 hover:border-emerald-200 dark:hover:border-emerald-800 transition-colors duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-10 h-10 text-emerald-500 flex-shrink-0"><path d="M21.801 10A10 10 0 1 1 17 3.335"/><path d="m9 11 3 3L22 4"/></svg>
          <div>
            <p class="font-bold text-slate-900 dark:text-white">Prima visita gratuita</p>
            <p class="text-sm text-slate-500 dark:text-slate-400">Valutazione senza impegno</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text');
  const btnIcon = document.getElementById('btn-icon');
  const btnSpinner = document.getElementById('btn-spinner');

  function setLoading(loading: boolean) {
    submitBtn.disabled = loading;
    btnText?.classList.toggle('hidden', loading);
    btnIcon?.classList.toggle('hidden', loading);
    btnSpinner?.classList.toggle('hidden', !loading);
    submitBtn.classList.toggle('opacity-75', loading);
    submitBtn.classList.toggle('cursor-not-allowed', loading);
  }

  function showResult(success: boolean, message: string) {
    const existing = document.getElementById('form-result');
    if (existing) existing.remove();

    const div = document.createElement('div');
    div.id = 'form-result';
    div.className = success
      ? 'mt-4 p-4 rounded-xl bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-300 text-sm font-medium'
      : 'mt-4 p-4 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 text-sm font-medium';
    div.textContent = message;
    form.appendChild(div);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    setLoading(true);

    const data = new FormData(form);
    const payload = {
      name: data.get('name') as string,
      email: data.get('email') as string,
      phone: (data.get('phone') as string) || undefined,
      message: data.get('message') as string,
      serviceType: (data.get('service') as string) || 'other',
      urgency: 'medium' as const,
      consent: true as const,
      source: 'leadspark_contact_form'
    };

    try {
      const res = await fetch('/api/intake', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (res.ok) {
        form.reset();
        showResult(true, '✓ Richiesta inviata! Ti risponderemo entro 24 ore.');
      } else {
        const body = await res.json().catch(() => ({}));
        const msg = body?.error || `Errore ${res.status}. Riprova o contattaci direttamente.`;
        showResult(false, msg);
      }
    } catch {
      showResult(false, 'Errore di rete. Controlla la connessione e riprova.');
    } finally {
      setLoading(false);
    }
  });
</script>

<style>
  /* Contact info cards animation */
  .stagger-children > * {
    opacity: 0;
    transform: translateY(20px);
  }
  
  .stagger-children.visible > *:nth-child(1) {
    animation: slideUpCard 0.5s var(--ease-out-expo) 0ms forwards;
  }
  
  .stagger-children.visible > *:nth-child(2) {
    animation: slideUpCard 0.5s var(--ease-out-expo) 0.08s forwards;
  }
  
  .stagger-children.visible > *:nth-child(3) {
    animation: slideUpCard 0.5s var(--ease-out-expo) 0.16s forwards;
  }
  
  .stagger-children.visible > *:nth-child(4) {
    animation: slideUpCard 0.5s var(--ease-out-expo) 0.24s forwards;
  }
  
  @keyframes slideUpCard {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* Form input focus animation */
  .form-input:focus {
    transform: translateY(-1px);
  }
</style>
