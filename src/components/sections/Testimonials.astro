---

const testimonials = [
  {
    name: "Anna M.",
    role: "Atleta amatoriale",
    avatar: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=200&q=80",
    rating: 5,
    text: "Dopo un infortunio al ginocchio che mi aveva costretto a smettere di correre, il Dott. Rossi mi ha guidato in un percorso di recupero eccezionale. In 3 mesi sono tornata a correre meglio di prima. Professionalità e umanità fuori dal comune.",
    service: "Fisioterapia Sportiva"
  },
  {
    name: "Roberto C.",
    role: "Impiegato",
    avatar: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&q=80",
    rating: 5,
    text: "Soffrivo di mal di schiena cronico da anni. La Dott.ssa Bianchi ha individuato la causa e con un percorso di terapia manuale ha risolto un problema che pensavo dovesse accompagnarmi per sempre. Non posso che ringraziarla.",
    service: "Terapia Manuale"
  },
  {
    name: "Maria G.",
    role: "Pensionata",
    avatar: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=200&q=80",
    rating: 5,
    text: "Dopo l'operazione all'anca ero scoraggiata e impaurita. Il Dott. Verdi e tutto il team mi hanno accompagnata con pazienza e competenza. Oggi cammino senza dolore e ho riottenuto la mia autonomia. Grazie di cuore!",
    service: "Riabilitazione Post-operatoria"
  }
];
---

<section id="testimonials" class="section-padding bg-slate-50 dark:bg-slate-800/50">
  <div class="max-w-7xl mx-auto container-padding">
    {/* Section Header */}
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block px-4 py-1.5 rounded-full bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300 text-sm font-medium mb-4">
        Testimonianze
      </span>
      <h2 class="text-slate-900 dark:text-white mb-6">
        Cosa dicono i nostri
        <span class="text-gradient"> pazienti</span>
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-300">
        La soddisfazione dei nostri pazienti è la nostra più grande ricompensa. 
        Ecco alcune storie di chi ha ripreso il controllo del proprio corpo.
      </p>
    </div>

    {/* Testimonials Grid */}
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {testimonials.map((testimonial, index) => (
        <div class="group card-hover bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl shadow-sm relative">
          {/* Quote Icon */}
          <div class="absolute -top-4 left-6 w-8 h-8 rounded-full bg-blue-600 dark:bg-blue-500 flex items-center justify-center shadow-lg">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10.5h8m-8 3h5m-3.5-9l-4 1.5v11l4-1.5v-11zm9 0l-4 1.5v11l4-1.5v-11z"></path></svg>
          </div>

          <div class="p-6 pt-8">
            {/* Rating */}
            <div class="flex gap-1 mb-4">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg class={`w-5 h-5 ${i < testimonial.rating ? 'text-yellow-400 fill-yellow-400' : 'text-slate-300 dark:text-slate-600'}`} viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
              ))}
            </div>

            {/* Testimonial Text */}
            <blockquote class="text-slate-700 dark:text-slate-300 leading-relaxed mb-6">
              "{testimonial.text}"
            </blockquote>

            {/* Service Tag */}
            <div class="mb-6">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300 text-xs font-medium">
                {testimonial.service}
              </span>
            </div>

            {/* Author */}
            <div class="flex items-center gap-4 pt-4 border-t border-slate-100 dark:border-slate-700">
              <img 
                src={testimonial.avatar} 
                alt={testimonial.name}
                class="w-12 h-12 rounded-full object-cover ring-2 ring-white dark:ring-slate-700"
                loading="lazy"
              />
              <div>
                <p class="font-semibold text-slate-900 dark:text-white">{testimonial.name}</p>
                <p class="text-sm text-slate-500 dark:text-slate-400">{testimonial.role}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    {/* Trust Badges */}
    <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-6">
      {[
        { value: "4.9/5", label: "Valutazione media" },
        { value: "200+", label: "Recensioni verificate" },
        { value: "98%", label: "Pazienti soddisfatti" },
        { value: "85%", label: "Raccomandano" }
      ].map((stat) => (
        <div class="text-center p-4">
          <p class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white">{stat.value}</p>
          <p class="text-sm text-slate-500 dark:text-slate-400">{stat.label}</p>
        </div>
      ))}
    </div>

    {/* Review CTA */}
    <div class="mt-12 text-center">
      <p class="text-slate-600 dark:text-slate-400 mb-4">
        Hai già usufruito dei nostri servizi? Condividi la tua esperienza!
      </p>
      <a 
        href="#contact" 
        class="inline-flex items-center gap-2 text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-medium transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
        Lascia una recensione
      </a>
    </div>
  </div>
</section>
