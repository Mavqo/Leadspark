---
const testimonials = [
  {
    name: "Anna M.",
    role: "Atleta amatoriale",
    avatar: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=200&q=80",
    rating: 5,
    text: "Dopo un infortunio al ginocchio che mi aveva costretto a smettere di correre, il Dott. Rossi mi ha guidato in un percorso di recupero eccezionale. In 3 mesi sono tornata a correre meglio di prima. Professionalità e umanità fuori dal comune.",
    service: "Fisioterapia Sportiva"
  },
  {
    name: "Roberto C.",
    role: "Impiegato",
    avatar: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&q=80",
    rating: 5,
    text: "Soffrivo di mal di schiena cronico da anni. La Dott.ssa Bianchi ha individuato la causa e con un percorso di terapia manuale ha risolto un problema che pensavo dovesse accompagnarmi per sempre. Non posso che ringraziarla.",
    service: "Terapia Manuale"
  },
  {
    name: "Maria G.",
    role: "Pensionata",
    avatar: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=200&q=80",
    rating: 5,
    text: "Dopo l'operazione all'anca ero scoraggiata e impaurita. Il Dott. Verdi e tutto il team mi hanno accompagnata con pazienza e competenza. Oggi cammino senza dolore e ho riottenuto la mia autonomia. Grazie di cuore!",
    service: "Riabilitazione Post-operatoria"
  }
];

const trustStats = [
  { value: "4.9/5", label: "Valutazione media" },
  { value: "200+", label: "Recensioni verificate" },
  { value: "98%", label: "Pazienti soddisfatti" },
  { value: "85%", label: "Raccomandano" }
];
---

<section id="testimonials" class="section-padding bg-slate-50 dark:bg-slate-800/50">
  <div class="max-w-7xl mx-auto container-padding">
    {/* Section Header */}
    <div class="text-center max-w-3xl mx-auto mb-16 reveal">
      <span class="inline-block px-4 py-1.5 rounded-full bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300 text-sm font-semibold mb-4">
        Testimonianze
      </span>
      <h2 class="text-slate-900 dark:text-white mb-6">
        Cosa dicono i nostri
        <span class="text-gradient"> pazienti</span>
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
        La soddisfazione dei nostri pazienti è la nostra più grande ricompensa. 
        Ecco alcune storie di chi ha ripreso il controllo del proprio corpo.
      </p>
    </div>

    {/* Testimonials Grid */}
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 stagger-children">
      {testimonials.map((testimonial) => (
        <article class="group bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-500 relative">
          {/* Quote Icon */}
          <div class="absolute -top-4 left-6 w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center shadow-lg shadow-blue-500/30 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10.5h8m-8 3h5m-3.5-9l-4 1.5v11l4-1.5v-11zm9 0l-4 1.5v11l4-1.5v-11z"></path>
            </svg>
          </div>

          <div class="p-6 pt-10">
            {/* Rating */}
            <div class="flex gap-1 mb-4">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg class={`w-5 h-5 transition-transform duration-200 ${i < testimonial.rating ? 'text-yellow-400 fill-yellow-400 group-hover:scale-110' : 'text-slate-300 dark:text-slate-600'} ${i < testimonial.rating ? `delay-${i * 50}` : ''}`} viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                </svg>
              ))}
            </div>

            {/* Testimonial Text */}
            <blockquote class="text-slate-700 dark:text-slate-300 leading-relaxed mb-6 text-base">
              "{testimonial.text}"
            </blockquote>

            {/* Service Tag */}
            <div class="mb-6">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300 text-xs font-semibold">
                {testimonial.service}
              </span>
            </div>

            {/* Author */}
            <div class="flex items-center gap-4 pt-4 border-t border-slate-100 dark:border-slate-700">
              <img 
                src={testimonial.avatar} 
                alt={testimonial.name}
                class="w-12 h-12 rounded-full object-cover ring-2 ring-white dark:ring-slate-700 group-hover:ring-blue-200 dark:group-hover:ring-blue-800 transition-all duration-300"
                loading="lazy"
                decoding="async"
              />
              <div>
                <p class="font-bold text-slate-900 dark:text-white">{testimonial.name}</p>
                <p class="text-sm text-slate-500 dark:text-slate-400">{testimonial.role}</p>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    {/* Trust Badges */}
    <div class="mt-16 lg:mt-20 reveal">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 lg:gap-8">
        {trustStats.map((stat) => (
          <div class="text-center p-6 rounded-2xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 group">
            <p class="text-3xl lg:text-4xl font-bold text-slate-900 dark:text-white mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors duration-300">{stat.value}</p>
            <p class="text-sm text-slate-600 dark:text-slate-400 font-medium">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>

    {/* Review CTA */}
    <div class="mt-12 text-center reveal">
      <p class="text-slate-600 dark:text-slate-400 mb-4">
        Hai già usufruito dei nostri servizi? Condividi la tua esperienza!
      </p>
      <a 
        href="#contact" 
        class="inline-flex items-center gap-2 text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-semibold transition-colors duration-200 group"
      >
        <svg class="w-5 h-5 group-hover:scale-110 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
        </svg>
        Lascia una recensione
      </a>
    </div>
  </div>
</section>

<style>
  /* Stagger animation for testimonial cards */
  .stagger-children > * {
    opacity: 0;
    transform: translateY(20px);
  }
  
  .stagger-children.visible > *:nth-child(1) {
    animation: slideUpCard 0.6s var(--ease-out-expo) 0ms forwards;
  }
  
  .stagger-children.visible > *:nth-child(2) {
    animation: slideUpCard 0.6s var(--ease-out-expo) 0.1s forwards;
  }
  
  .stagger-children.visible > *:nth-child(3) {
    animation: slideUpCard 0.6s var(--ease-out-expo) 0.2s forwards;
  }
  
  @keyframes slideUpCard {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* Star rating hover animation */
  .group:hover .text-yellow-400 {
    animation: starPulse 0.3s ease-out;
  }
  
  @keyframes starPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.2); }
  }
</style>
