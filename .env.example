# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# n8n Webhook Configuration
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/lead
N8N_INTAKE_WEBHOOK_URL=https://your-n8n-instance/webhook/intake
WEBHOOK_SECRET=your-webhook-secret

# Admin Authentication (for protected endpoints)
ADMIN_TOKEN=your-secure-admin-token

# Persistent data directory for leads/chat sessions (default: ./data)
LEADSPARK_DATA_DIR=./data

# Optional: rate limiter persistence/tuning
# RATE_LIMIT_STORAGE_FILE=./data/rate-limits.json
# RATE_LIMIT_MAX_ENTRIES=5000
# RATE_LIMIT_CHAT_IP_WINDOW_MS=60000
# RATE_LIMIT_CHAT_IP_MAX_REQUESTS=30
# RATE_LIMIT_CHAT_SESSION_WINDOW_MS=60000
# RATE_LIMIT_CHAT_SESSION_MAX_REQUESTS=20
# RATE_LIMIT_LEAD_IP_WINDOW_MS=60000
# RATE_LIMIT_LEAD_IP_MAX_REQUESTS=10
# RATE_LIMIT_WEBHOOK_IP_WINDOW_MS=60000
# RATE_LIMIT_WEBHOOK_IP_MAX_REQUESTS=60
# RATE_LIMIT_ADMIN_LEAD_WINDOW_MS=60000
# RATE_LIMIT_ADMIN_LEAD_MAX_REQUESTS=5

# Optional: Twilio (for WhatsApp notifications)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_WHATSAPP_NUMBER=+14155238886

# Optional: Resend (for email fallback)
RESEND_API_KEY=re_your-resend-key
